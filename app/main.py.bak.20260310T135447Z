                    relief = _aqg_relief_decide(self, best or row, preferred_side)

                    if not base and relief["allow"] and bool(_aqg_cfg.get("throughput_relief_enabled", True)):
                        _aqg_stats["candidate_allowed"] += 1
                        s = dict(relief["sample"])
                        s["decision"] = "throughput_relief_allow"
                        _aqg_sample(s)
                        return True
                except Exception as e:
                    try:
                        _aqg_stats["last_error"] = repr(e)
                    except Exception:
                        pass
                return base
            _aqg_candidate_wrapper_v30._architect_quant_gate_v30_wrapped = True
            TradingBot._is_shadow_candidate = _aqg_candidate_wrapper_v30

            wm = _aqg_stats.setdefault("wrapped_methods", [])

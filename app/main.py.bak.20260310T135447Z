            sigma = _aqg_clamp(_aqg_float(sigma, _aqg_cfg["default_atm_sigma"]), _aqg_cfg["min_sigma"], _aqg_cfg["max_sigma"])
            if t_years is None:
                t_years = 1.0 / 365.0
            t_years = max(0.0, _aqg_float(t_years, 1.0 / 365.0))
            res = fair - (q * _aqg_cfg["gamma"] * (sigma ** 2) * t_years)
            return _aqg_clamp(res, 0.01, 0.99)

                out["mode"] = status.get("mode")
                out["live_armed"] = status.get("live_armed")
                out["loop_error"] = status.get("loop_error")
                out["eligible_markets"] = (
                    status.get("eligible_markets")
                    or ((status.get("health") or {}).get("market_pipeline") or {}).get("eligible_markets")
                )
                out["paper_using_newest_infra"] = status.get("paper_using_newest_infra")
        except Exception:
            pass
        return out

    def _arch_v16_payload():
        dbp = _arch_v16_db_path()
        payload = {
            "ok": True,
            "policy": "paper_only__markouts_truth_route_v16",
            "db_exists": dbp.exists(),
            "db_path": str(dbp),
            "tables": {},
            "recent_activity": {},
            "status_summary": _arch_v16_status_summary(),
            "markout_runtime_stats": globals().get("_arch_markout_v12_stats") or {},
            "markout_db_bridge_stats": globals().get("_arch_markout_db_v14_stats") or globals().get("_arch_markouts_db_bridge_v14_stats") or {},
            "note": "truth_route_reads_sqlite_directly__zero_markouts_mean_no_fresh_opens_or_no_capture_hook_firing",
        }

        if not dbp.exists():
            return payload

        conn = _arch_sqlite3_v16.connect(str(dbp))
        try:
            for t in ("shadow_positions", "shadow_trades", "candidate_events"):
                payload["tables"][t] = {
                    "count": _arch_v16_count(conn, t),
                    "columns": _arch_v16_cols(conn, t)[:20],
                    "recent_rows": _arch_v16_recent_rows(conn, t, limit=5),
                }

            payload["recent_activity"]["shadow_positions_opened_last_30m"] = _arch_v16_recent_opens(conn, 30)
            payload["recent_activity"]["shadow_positions_opened_last_120m"] = _arch_v16_recent_opens(conn, 120)

            sp_count = payload["tables"].get("shadow_positions", {}).get("count")
            ce_count = payload["tables"].get("candidate_events", {}).get("count")
            payload["harvest_readiness"] = {
                "has_open_positions_now": bool((sp_count or 0) > 0),
                "has_any_candidate_events": bool((ce_count or 0) > 0),
                "can_markout_now": bool((sp_count or 0) > 0),
            }
            return payload
        finally:
            conn.close()

    def _arch_v16_route_exists(path):
        try:
            return any(getattr(r, "path", None) == path for r in app.router.routes)
        except Exception:
            return False


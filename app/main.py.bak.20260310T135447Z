    def _aqg_v40_eval_variants():
        try:
            from app.strategy_lab.storage import get_conn
        except Exception as e:
            _aqg_stats["paper_guardrails_v40"]["last_error"] = repr(e)
            return {}

        conn = get_conn()
        try:
            rows = conn.execute("""
                SELECT variant_name, realized_pnl, close_reason
                FROM shadow_trades
                WHERE closed_at IS NOT NULL
                ORDER BY id DESC
                LIMIT ?
            """, (_AQG_V40_CFG["recent_closed_limit"],)).fetchall()
        finally:
            conn.close()

        by_variant = {}
        for r in rows:
            v = str(r["variant_name"] or "unknown")
            bucket = by_variant.setdefault(v, {
                "closed": 0,
                "wins": 0,
                "losses": 0,
                "realized_pnl": 0.0,
                "close_reason_counts": {},
                "blocked": False,
                "block_reason": None,
            })
            bucket["closed"] += 1
            pnl = float(r["realized_pnl"] or 0.0)
            bucket["realized_pnl"] += pnl
            if pnl > 0:
                bucket["wins"] += 1
            elif pnl < 0:
                bucket["losses"] += 1
            cr = str(r["close_reason"] or "unknown")
            bucket["close_reason_counts"][cr] = int(bucket["close_reason_counts"].get(cr, 0) or 0) + 1

        for v, b in by_variant.items():
            closed = int(b["closed"] or 0)
            win_rate = (float(b["wins"]) / closed) if closed else 0.0
            model_det = int(b["close_reason_counts"].get("model_deterioration_v2", 0) or 0)
            model_det_share = (float(model_det) / closed) if closed else 0.0

            b["win_rate_closed"] = round(win_rate, 4) if closed else None
            b["realized_pnl"] = round(float(b["realized_pnl"]), 6)
            b["model_deterioration_share"] = round(model_det_share, 4) if closed else None

            if v in _AQG_V40_CFG["hard_block_variants"]:
                b["blocked"] = True
                b["block_reason"] = "hard_block_variant"
                continue

            if _AQG_V40_CFG["allow_variants"] and v not in _AQG_V40_CFG["allow_variants"]:
                b["blocked"] = True
                b["block_reason"] = "not_in_allow_variants"
                continue

            if closed < _AQG_V40_CFG["min_closed_trades_for_block"]:
                continue

            if float(b["realized_pnl"]) <= float(_AQG_V40_CFG["max_realized_pnl"]):
                b["blocked"] = True
                b["block_reason"] = "realized_pnl_below_guardrail"
                continue


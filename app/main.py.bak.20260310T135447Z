    def _arch_iq_dvol(snapshot):
        for key in ("deribit_dvol", "implied_vol", "dynamic_annual_vol_btc"):
            val = _arch_iq_field(snapshot, key, None)
            if val is not None:
                out = _arch_iq_safe_float(val, 0.60)
                if out > 0:

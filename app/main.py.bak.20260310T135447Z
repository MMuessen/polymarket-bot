    def _arch_ie_v5_callable_names(cls):
        out = []
        try:
            for name in dir(cls):
                if name.startswith("__"):
                    continue
                try:
                    val = getattr(cls, name)
                except Exception:
                    continue
                if callable(val):
                    out.append(name)
        except Exception as e:
            _arch_ie_v5_stats["last_error"] = repr(e)
        return sorted(set(out))

    def _arch_ie_v5_is_candidate(name):
        n = str(name or "").lower()

        exact = {
            "_should_enter", "should_enter",
            "_should_open", "should_open",
            "_open_shadow_position", "open_shadow_position",
            "_open_paper_position", "open_paper_position",
            "_try_open_shadow", "try_open_shadow",
            "_maybe_open_shadow", "maybe_open_shadow",
            "_consider_entry", "consider_entry",
            "_maybe_enter_trade", "maybe_enter_trade",
            "_open_trade", "open_trade",
            "_open_position", "open_position",
        }
        if n in exact:
            return True

        enterish = any(tok in n for tok in ["enter", "open", "candidate", "consider", "maybe"])
        tradeish = any(tok in n for tok in ["shadow", "paper", "trade", "position", "opportunity"])
        bad = any(tok in n for tok in ["close", "exit", "mark", "status", "debug", "route", "report"])
        return enterish and tradeish and not bad


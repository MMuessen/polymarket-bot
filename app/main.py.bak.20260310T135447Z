                return obj.get(key, default)
            return getattr(obj, key, default)
        except Exception:
            return default

    def _arch_iph_v3_sf(v, default=0.0):
        try:
            if v is None:
                return default
            if isinstance(v, str) and not v.strip():
                return default
            return float(v)
        except Exception:
            return default

    def _arch_iph_v3_snapshot_map(self_ref):
        out = {}
        try:
            ms = getattr(self_ref, "market_snapshots", {}) or {}
            if isinstance(ms, dict):
                for ticker, row in ms.items():
                    try:
                        if isinstance(row, dict):
                            out[ticker] = dict(row)
                        elif hasattr(row, "to_dict") and callable(row.to_dict):
                            out[ticker] = row.to_dict()
                    except Exception:
                        continue
        except Exception as e:
            _arch_iph_v3_stats["last_error"] = repr(e)
        _arch_iph_v3_stats["snapshot_rows_last"] = len(out)
        return out

    def _arch_iph_v3_db_latest_by_ticker():
        db_path = _Path("data/strategy_lab.db")
        out = {}
        if not db_path.exists():
            return out
        try:
            conn = _sqlite3.connect(str(db_path))
            conn.row_factory = _sqlite3.Row
            cur = conn.cursor()
            _arch_iph_v3_stats["db_reads"] += 1

            cols = [r[1] for r in cur.execute("PRAGMA table_info(market_opportunities)").fetchall()]
            wanted = [
                "ticker",
                "best_side",
                "best_exec_edge",
                "spread",
                "inventory_side_penalty",
                "inventory_quote_size_mult",
                "inventory_reservation_shift_cents",
                "lip_rebate_estimate_base",
                "maker_edge_after_rebate",
                "maker_edge_after_rebate_and_inventory",
                "edge_after_rebate_and_inventory",
                "order_book_imbalance",
                "maker_toxicity_bps_1s",
                "cluster_inventory_bias",
                "cluster_key",
                "yes_ask",
                "no_ask",
                "yes_bid",
                "no_bid",
                "mid",
                "updated_at",
                "created_at",
                "ts",
                "id",
            ]
            chosen = [c for c in wanted if c in cols]
            if "ticker" not in chosen:
                conn.close()
                return out

            order_col = "id" if "id" in cols else ("ts" if "ts" in cols else ("updated_at" if "updated_at" in cols else "created_at"))
            sql = f"SELECT {', '.join(chosen)} FROM market_opportunities ORDER BY {order_col} DESC LIMIT 600"
            rows = cur.execute(sql).fetchall()

            for row in rows:
                d = dict(row)
                t = d.get("ticker")
                if t and t not in out:
                    out[t] = d

            _arch_iph_v3_stats["db_rows_last"] = len(rows)
            conn.close()
        except Exception as e:
            _arch_iph_v3_stats["last_error"] = repr(e)
        return out

    def _arch_iph_v3_hydrated_rows(self_ref, status):
        health = (status.get("health") or {}) if isinstance(status, dict) else {}
        mp = (health.get("market_pipeline") or {}) if isinstance(health, dict) else {}
        watched = mp.get("watched_market_samples") or []
        watched = [r for r in watched if isinstance(r, dict)]

        snapshots = _arch_iph_v3_snapshot_map(self_ref)
        db_rows = _arch_iph_v3_db_latest_by_ticker()

        tickers = []
        for row in watched:
            t = row.get("ticker")
            if t and t not in tickers:
                tickers.append(t)
        for t in snapshots.keys():
            if t not in tickers:
                tickers.append(t)

        merged = []
        for t in tickers[:60]:
            row = {"ticker": t}
            if t in watched and isinstance(watched, dict):
                row.update(watched[t])
            else:
                for wr in watched:
                    if wr.get("ticker") == t:
                        row.update(wr)
                        break
            if t in snapshots:
                row.update({k: v for k, v in snapshots[t].items() if v is not None})
            if t in db_rows:
                row.update({k: v for k, v in db_rows[t].items() if v is not None})
            merged.append(row)

        _arch_iph_v3_stats["hydrated_rows_last"] = len(merged)
        _arch_iph_v3_stats["source_last"] = "watched_market_samples+market_snapshots+market_opportunities"
        return merged

    def _arch_iph_v3_preview_row(row):
        best_side = str(
            _arch_iph_v3_get(
                row,
                "best_side",
                _arch_iph_v3_get(row, "maker_side", _arch_iph_v3_get(row, "side", "yes")),
            )
        ).lower()

        yes_ask = _arch_iph_v3_get(row, "yes_ask", None)
        no_ask = _arch_iph_v3_get(row, "no_ask", None)
        yes_bid = _arch_iph_v3_get(row, "yes_bid", None)
        no_bid = _arch_iph_v3_get(row, "no_bid", None)

        entry_price = _arch_iph_v3_get(row, "entry_price", None)
        if entry_price is None:
            entry_price = no_ask if best_side == "no" else yes_ask

        spread = _arch_iph_v3_get(row, "spread", None)
        if spread is None:
            ya = _arch_iph_v3_sf(yes_ask, None)

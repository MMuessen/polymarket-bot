# --- dict/object field helper ---
def _field(obj, name, default=None):
    if obj is None:
        return default
    if isinstance(obj, dict):
        return obj.get(name, default)
    try:
        return getattr(obj, name)
    except Exception:
        pass
    try:
        return obj[name]
    except Exception:
        return default



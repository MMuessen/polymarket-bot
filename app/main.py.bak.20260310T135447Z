            "enabled_symbols": sorted(list(_AQG_V52["enabled_symbols"])),
            "max_cached_tickers": _AQG_V52["max_cached_tickers"],
        },
        "refresh_rebuilds": 0,
        "rebuilt_cached_counts": {},
        "cached_mix_head": [],
        "last_error": None,
    })

    def _v52_symbol_from_ticker(ticker):
        s = str(ticker or "").upper()
        if s.startswith("KXBTC-"):
            return "BTC"
        if s.startswith("KXETH-"):
            return "ETH"
        if s.startswith("KXSOL-"):
            return "SOL"
        return None

    def _v52_event_markets(event):
        try:
            if isinstance(event, dict):
                mkts = event.get("markets") or event.get("nested_markets") or []
            else:
                mkts = getattr(event, "markets", None) or getattr(event, "nested_markets", None) or []
            return mkts if isinstance(mkts, list) else []
        except Exception:
            return []

    def _v52_event_ticker(event):
        try:
            if isinstance(event, dict):
                return event.get("series_ticker") or event.get("event_ticker") or event.get("ticker")
            return getattr(event, "series_ticker", None) or getattr(event, "event_ticker", None) or getattr(event, "ticker", None)
        except Exception:
            return None

    def _v52_market_ticker(m):
        try:
            if isinstance(m, dict):
                return m.get("ticker")
            return getattr(m, "ticker", None)
        except Exception:
            return None

    def _v52_build_pairs_from_events(events):
        by_symbol = {k: [] for k in _AQG_V52["series_order"]}
        seen = set()

        for event in (events or []):
            series_ticker = _v52_event_ticker(event)
            series_symbol = None
            st = str(series_ticker or "").upper()
            if st.startswith("KXBTC"):
                series_symbol = "BTC"
            elif st.startswith("KXETH"):
                series_symbol = "ETH"
            elif st.startswith("KXSOL"):
                series_symbol = "SOL"

            for m in _v52_event_markets(event):
                ticker = _v52_market_ticker(m)
                if not ticker:
                    continue
                symbol = _v52_symbol_from_ticker(ticker) or series_symbol
                if symbol not in _AQG_V52["enabled_symbols"]:
                    continue
                key = (str(ticker), str(symbol))
                if key in seen:
                    continue
                seen.add(key)
                by_symbol.setdefault(symbol, []).append((str(ticker), str(symbol)))

        mixed = []
        max_len = max((len(v) for v in by_symbol.values()), default=0)
        for i in range(max_len):
            for sym in _AQG_V52["series_order"]:
                arr = by_symbol.get(sym) or []
                if i < len(arr):
                    mixed.append(arr[i])

        if _AQG_V52["max_cached_tickers"]:
            mixed = mixed[: int(_AQG_V52["max_cached_tickers"])]

        counts = {k: len(v) for k, v in by_symbol.items() if v}
        return mixed, counts

    _TB = globals().get("TradingBot", None)
    if _TB is not None:
        _prev_refresh_markets_v52 = getattr(_TB, "refresh_markets", None)
        if callable(_prev_refresh_markets_v52) and not getattr(_prev_refresh_markets_v52, "_architect_multi_asset_cache_rebuild_v52_wrapped", False):
            async def _aqg_refresh_markets_v52(self, *args, **kwargs):
                try:
                    fetcher = globals().get("_arch_kxbtc_fetch_events")
                    if callable(fetcher):
                        events = fetcher()
                        mixed, counts = _v52_build_pairs_from_events(events)

                        if mixed:
                            setattr(self, "cached_crypto_tickers", mixed)
                            _aqg_stats["data_truth_v52"]["refresh_rebuilds"] = int(
                                _aqg_stats["data_truth_v52"].get("refresh_rebuilds", 0) or 0
                            ) + 1
                            _aqg_stats["data_truth_v52"]["rebuilt_cached_counts"] = counts
                            _aqg_stats["data_truth_v52"]["cached_mix_head"] = mixed[:30]
                except Exception as e:
                    _aqg_stats["data_truth_v52"]["last_error"] = repr(e)

                return await _prev_refresh_markets_v52(self, *args, **kwargs)

            _aqg_refresh_markets_v52._architect_multi_asset_cache_rebuild_v52_wrapped = True
            setattr(_TB, "refresh_markets", _aqg_refresh_markets_v52)


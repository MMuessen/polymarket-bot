    def _aqg_edge_for_side(row, side):
        d = _aqg_row_dict(row)
        edge = _aqg_float(d.get("edge_after_rebate_and_inventory", d.get("best_exec_edge")), None)
        if edge is not None:
            return edge
        fair_yes = _aqg_clamp(_aqg_float(d.get("fair_yes", d.get("fair_yes_live_v20", 0.5)), 0.5), 0.0, 1.0)
        yes_ask = _aqg_float(d.get("yes_ask", d.get("entry_price")), None)
        no_ask = _aqg_float(d.get("no_ask", None), None)
        if str(side).lower() == "yes":
            if yes_ask is None:
                return None
            return fair_yes - yes_ask
        if no_ask is None:
            return None
        return (1.0 - fair_yes) - no_ask

    def _aqg_relief_decide(bot_obj, row, side):
        try:
            _aqg_stats["throughput_relief"]["considered"] += 1
        except Exception:
            pass

        d = _aqg_row_dict(row)
        spread = _aqg_float(d.get("spread", d.get("spread_paid")), 999.0)
        obi = _aqg_obi(d)
        tox = _aqg_tox(d)
        edge = _aqg_edge_for_side(d, side)

        reasons = []
        if edge is None:
            reasons.append("relief_missing_edge")
        if tox is None or float(tox) > float(_aqg_cfg.get("throughput_relief_toxicity_max", 2.0)):
            reasons.append("relief_toxic")
        if spread is None or float(spread) > float(_aqg_cfg.get("throughput_relief_wide_spread_max", 0.04)):
            reasons.append("relief_spread_too_wide")

        if str(side).lower() == "yes":
            if obi is not None and float(obi) < float(_aqg_cfg.get("throughput_relief_obi_yes_floor", 0.0)):
                reasons.append("relief_hostile_obi_yes")
        else:
            if obi is not None and float(obi) > float(_aqg_cfg.get("throughput_relief_obi_no_ceiling", 0.0)):
                reasons.append("relief_hostile_obi_no")

        if edge is not None:
            if spread is not None and float(spread) <= float(_aqg_cfg.get("throughput_relief_tight_spread_max", 0.02)):
                if float(edge) < float(_aqg_cfg.get("throughput_relief_min_edge_tight", 0.020)):
                    reasons.append("relief_edge_too_small_tight")
            else:
                if float(edge) < float(_aqg_cfg.get("throughput_relief_min_edge_wide", 0.025)):
                    reasons.append("relief_edge_too_small_wide")

        allow = len(reasons) == 0

        try:
            if allow:
                _aqg_stats["throughput_relief"]["allowed"] += 1
            else:
                _aqg_stats["throughput_relief"]["blocked"] += 1
        except Exception:
            pass

        return {
            "allow": allow,
            "sample": {
                "ticker": d.get("ticker"),
                "side": side,
                "spread": spread,
                "obi": obi,
                "toxicity_bps_1s": tox,

def _architect_compute_trade_stats(rows):

    stats={
        "total":0,
        "wins":0,
        "losses":0,
        "win_rate":0,
        "variants":{},
        "exit_reasons":{}
    }

    for r in rows:

        stats["total"]+=1

        pnl=r.get("pnl",0)

        if pnl>0:
            stats["wins"]+=1
        else:
            stats["losses"]+=1

        v=r.get("variant_name","unknown")

        if v not in stats["variants"]:
            stats["variants"][v]={"pnl":0,"trades":0}

        stats["variants"][v]["pnl"]+=pnl
        stats["variants"][v]["trades"]+=1

        reason=r.get("close_reason","unknown")

        stats["exit_reasons"][reason]=stats["exit_reasons"].get(reason,0)+1

    if stats["total"]>0:
        stats["win_rate"]=round(stats["wins"]/stats["total"],3)

    return stats



            cluster_key = _arch_iegp_field(s, "cluster_key", None) or (ticker.split("-B")[0] if ticker else None)
            cluster_bias = _arch_iegp_cluster_bias(shadow_positions, cluster_key, best_side)

            # conservative preview thresholds
            reservation_price = max(0.0, min(0.99, entry_price - max(0.0, cluster_bias) * 0.01))
            reasons = []
            if entry_price > reservation_price + 1e-9:
                reasons.append("reservation_price")
            if best_side == "yes" and obi <= -0.50:
                reasons.append("obi_against_yes")
            if best_side == "no" and obi >= 0.50:
                reasons.append("obi_against_no")
            if tox1 >= 10.0:
                reasons.append("toxic_flow_1s")
            if spread >= 0.10:
                reasons.append("wide_spread")
            if cluster_bias >= 3.0:
                reasons.append("inventory_stack_same_side")
            if edge_after_rebate_and_inventory <= 0:
                reasons.append("non_positive_edge")

            out.append({
                "ticker": ticker,
                "best_side": best_side,
                "entry_price": round(entry_price, 4),
                "reservation_price_preview": round(reservation_price, 4),

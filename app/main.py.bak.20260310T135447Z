        return 0.60

    def _arch_iq_skew(snapshot):
        for key in ("skew_25d_put_minus_call", "deribit_skew_25d", "deribit_skew"):
            val = _arch_iq_field(snapshot, key, None)
            if val is not None:
                return max(-1.50, min(_arch_iq_safe_float(val, 0.0), 1.50))
        return 0.0

    def _arch_iq_local_sigma(snapshot, strike, spot):
        sigma_atm = _arch_iq_dvol(snapshot)
        skew = _arch_iq_skew(snapshot)
        try:
            strike = float(strike)
            spot = float(spot)
            if strike <= 0 or spot <= 0:
                return sigma_atm
            sigma_k = sigma_atm * (1.0 + skew * ((strike - spot) / spot))
            return max(0.10, min(float(sigma_k), 2.50))
        except Exception:
            return sigma_atm

    def _arch_iq_bucket_fair_yes(self_ref, snapshot):
        spot = _arch_iq_spot(self_ref, snapshot)
        low = _arch_iq_field(snapshot, "floor_strike", None)
        high = _arch_iq_field(snapshot, "cap_strike", None)
        hours = None
        try:
            hours = self_ref._hours_to_expiry(snapshot)
        except Exception:
            hours = None

        if spot > 0 and low is not None and high is not None and hours is not None:
            low = _arch_iq_safe_float(low, 0.0)
            high = _arch_iq_safe_float(high, 0.0)
            if low > 0 and high > low:
                t_years = max(float(hours), 1.0 / 60.0) / (24.0 * 365.0)
                root_t = max(_arch_math.sqrt(t_years), 1e-6)
                sigma_low = _arch_iq_local_sigma(snapshot, low, spot)
                sigma_high = _arch_iq_local_sigma(snapshot, high, spot)
                z_low = _arch_math.log(max(low, 1e-9) / max(spot, 1e-9)) / max(sigma_low * root_t, 1e-6)
                z_high = _arch_math.log(max(high, 1e-9) / max(spot, 1e-9)) / max(sigma_high * root_t, 1e-6)
                fair_yes = _arch_iq_norm_cdf(z_high) - _arch_iq_norm_cdf(z_low)
                return max(0.001, min(float(fair_yes), 0.999))

        existing = _arch_iq_field(snapshot, "fair_yes", None)
        if existing is not None:
            return max(0.001, min(_arch_iq_safe_float(existing, 0.5), 0.999))
        return 0.5


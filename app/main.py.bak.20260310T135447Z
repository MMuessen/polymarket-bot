        if edge < required_edge:
            reasons.append("relief_edge_below_floor")
        if tox >= 4.0:
            reasons.append("relief_toxic_fill_risk_4bps")
        if side == "yes" and obi < -0.10:
            reasons.append("relief_obi_strongly_against_yes")
        if side == "no" and obi > 0.10:
            reasons.append("relief_obi_strongly_against_no")

        out = dict(best)

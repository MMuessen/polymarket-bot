            "vpin_like": round(float(vpin_like), 4),
            "cluster_inventory": round(float(cluster_inventory), 2),
            "inventory_penalty": round(float(inventory_penalty), 4),
            "reason": reason or "ok",
            "ticker": str(_arch_iq_hotfix_field(snapshot, "ticker", "")),
        }
        return (reason is None), (reason or "ok"), meta


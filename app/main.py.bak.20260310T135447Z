            total += qty if row_side == "yes" else -qty
        return float(total)

    def _arch_iq_reservation_price(self_ref, snapshot, side, fair_yes):
        fair_side = fair_yes if side == "yes" else (1.0 - fair_yes)
        cluster_inventory = _arch_iq_cluster_inventory(self_ref, snapshot)

        gamma = float(_arch_os.getenv("INSTITUTIONAL_GAMMA", "0.10"))
        hours = self_ref._hours_to_expiry(snapshot) or 0.0
        t_frac = min(max(float(hours) / 24.0, 0.02), 1.0)
        sigma = _arch_iq_dvol(snapshot)
        inventory_units = abs(cluster_inventory) / 100.0

        same_side_inventory = 0.0
        if side == "yes":
            same_side_inventory = max(cluster_inventory, 0.0)
        else:
            same_side_inventory = max(-cluster_inventory, 0.0)

        same_side_units = same_side_inventory / 100.0
        reservation_penalty = same_side_units * gamma * sigma * sigma * t_frac

        obi = _arch_iq_obi(snapshot, side)
        obi_bonus = 0.02 * obi

        rebate = _arch_iq_safe_float(_arch_iq_field(snapshot, "lip_rebate_estimate_base", None), 0.0)

        reservation = fair_side + obi_bonus + rebate - reservation_penalty
        reservation = max(0.01, min(float(reservation), 0.99))

        quote_mult = max(0.25, 1.0 - min(inventory_units / 6.0, 0.75))
        return {
            "reservation_price": reservation,
            "cluster_inventory": cluster_inventory,
            "inventory_quote_size_mult": quote_mult,
            "reservation_penalty": reservation_penalty,
            "obi_bonus": obi_bonus,
        }


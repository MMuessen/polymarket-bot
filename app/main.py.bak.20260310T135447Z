                    }
                    _arch_itr_v13_stats["dashboard_attaches"] += 1
            except Exception as e:
                _arch_itr_v13_stats["last_error"] = repr(e)
            return status

        TradingBot.dashboard_status = _arch_itr_v13_dashboard_status

    async def _arch_itr_v13_report():

                return None
            status = status or {}
            watched = (((status.get("health") or {}).get("market_pipeline") or {}).get("watched_market_samples") or [])
            for row in watched:
                if _arch_ie_v6_norm_ticker((row or {}).get("ticker")) == ticker:
                    return dict(row)
        except Exception as e:
            _arch_ie_v6_stats["last_error"] = repr(e)
        return None

    def _arch_ie_v6_get_snapshot_row(bot_ref, ticker):
        try:
            ms = getattr(bot_ref, "market_snapshots", {}) or {}
            if isinstance(ms, dict):
                row = ms.get(ticker)
                if row is None:
                    for k, v in ms.items():
                        if _arch_ie_v6_norm_ticker(k) == ticker:
                            row = v
                            break
                if row is not None:
                    if isinstance(row, dict):
                        return dict(row)
                    if hasattr(row, "to_dict") and callable(row.to_dict):
                        return row.to_dict()
                    return {
                        "ticker": getattr(row, "ticker", None),
                        "yes_bid": getattr(row, "yes_bid", None),
                        "yes_ask": getattr(row, "yes_ask", None),
                        "no_bid": getattr(row, "no_bid", None),
                        "no_ask": getattr(row, "no_ask", None),
                        "spread": getattr(row, "spread", None),
                        "best_side": getattr(row, "best_side", None),

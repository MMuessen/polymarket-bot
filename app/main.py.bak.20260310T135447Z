        return "yes", yes_edge

    def _arch_iq_obi(snapshot, side):
        raw = _arch_iq_raw(snapshot)
        bid_key = ("yes_bid_size_fp", "yes_ask_size_fp") if side == "yes" else ("no_bid_size_fp", "no_ask_size_fp")
        bid = _arch_iq_safe_float(raw.get(bid_key[0]) or _arch_iq_field(snapshot, bid_key[0], None), 0.0)
        ask = _arch_iq_safe_float(raw.get(bid_key[1]) or _arch_iq_field(snapshot, bid_key[1], None), 0.0)
        if (bid + ask) > 0:
            return max(-1.0, min((bid - ask) / (bid + ask), 1.0))

        obi = _arch_iq_field(snapshot, "order_book_imbalance", None)
        if obi is not None:
            return max(-1.0, min(_arch_iq_safe_float(obi, 0.0), 1.0))

        tape = _arch_iq_field(snapshot, "trade_tape_imbalance_15m", None)
        if tape is not None:
            return max(-1.0, min(_arch_iq_safe_float(tape, 0.0), 1.0))


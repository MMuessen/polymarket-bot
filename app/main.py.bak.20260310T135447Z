    def _arch_iq_hotfix_gate(self_ref, snapshot, side, entry_price):
        fair_yes = _arch_iq_hotfix_bucket_fair_yes(self_ref, snapshot)
        fair_side = fair_yes if side == "yes" else (1.0 - fair_yes)
        fee = _arch_iq_hotfix_side_fee(snapshot, side)
        edge = fair_side - float(entry_price) - fee
        obi = _arch_iq_hotfix_obi(snapshot, side)
        vpin_like = _arch_iq_hotfix_vpin_like(snapshot)
        cluster_inventory = _arch_iq_hotfix_cluster_inventory(snapshot)

        hours = None
        try:
            hours = self_ref._hours_to_expiry(snapshot)
        except Exception:
            hours = None
        hours = _arch_iq_hotfix_safe_float(hours, 0.0)

        gamma = _arch_iq_hotfix_safe_float(_arch_os.getenv("INSTITUTIONAL_GAMMA", "0.10"), 0.10)
        sigma = _arch_iq_hotfix_dvol(snapshot)
        t_frac = min(max(hours / 24.0, 0.02), 1.0)

        same_side_inventory = max(cluster_inventory, 0.0) if side == "yes" else max(-cluster_inventory, 0.0)
        same_side_units = same_side_inventory / 100.0
        inventory_penalty = same_side_units * gamma * sigma * sigma * t_frac
        obi_bonus = 0.02 * obi

        reservation_price = max(0.01, min(fair_side + obi_bonus - inventory_penalty, 0.99))

        reason = None
        if entry_price <= 0.0 or entry_price >= 1.0:
            reason = "bad_entry_price"
        elif entry_price > reservation_price:
            reason = "reservation_price_block"
        elif side == "yes" and obi < -0.50:

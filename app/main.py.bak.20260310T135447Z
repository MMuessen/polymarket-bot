                out.append(v)
            out.sort(key=lambda x: (-x["trades"], x["realized_pnl"]))
            cohort["post_exit_v2_by_reason"] = out[:20]

            conn.close()
        except Exception as e:
            cohort["error"] = repr(e)

        status["post_exit_v2_cohorts"] = cohort

        try:

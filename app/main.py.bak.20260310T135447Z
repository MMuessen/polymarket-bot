    def _arch_iq_hotfix_raw(snapshot):
        raw = _arch_iq_hotfix_field(snapshot, "raw", None)
        return raw if isinstance(raw, dict) else {}

    def _arch_iq_hotfix_norm_cdf(x):
        return 0.5 * (1.0 + _arch_math.erf(float(x) / _arch_math.sqrt(2.0)))

    def _arch_iq_hotfix_event_key(snapshot):
        raw = _arch_iq_hotfix_raw(snapshot)
        event_ticker = raw.get("event_ticker")
        if event_ticker:

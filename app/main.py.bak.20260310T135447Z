        vals = sorted([px for ts, px in hist if ts >= cutoff and px is not None])
        n = len(vals)
        if n < 12:
            return None, n
        drop = min(12, max(1, int(n * 0.2)))
        mid = vals[drop:n-drop] if n > (2 * drop) else vals
        if not mid:

            except Exception:
                try:
                    out.append({k: r[k] for k in r.keys()})
                except Exception:
                    pass
        return out

    def _sb2_table_exists(conn, name):
        try:
            row = conn.execute(
                "SELECT name FROM sqlite_master WHERE type='table' AND name = ?",
                (name,),
            ).fetchone()
            return row is not None
        except Exception:
            return False

    def _sb2_query_rows(conn, sql, args=()):

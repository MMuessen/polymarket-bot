    def _sb2_safe_read(path, max_chars=250000):
        try:
            p = _sb2_Path(path)
            if not p.exists():
                return {
                    "path": str(path),
                    "exists": False,
                    "chars": 0,
                    "truncated": False,
                    "text": None,
                }
            text = p.read_text(encoding="utf-8", errors="ignore")
            return {
                "path": str(path),
                "exists": True,
                "chars": len(text),
                "truncated": len(text) > max_chars,
                "text": text[:max_chars],
            }
        except Exception as e:

    def _arch_mh_parse_dt(value):
        if value is None:
            return None
        if isinstance(value, _arch_dt):
            dt = value
        else:
            try:
                dt = _arch_dt.fromisoformat(str(value).replace("Z", "+00:00"))
            except Exception:
                return None
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=_arch_tz.utc)
        return dt

    def _arch_mh_iso(value):
        dt = _arch_mh_parse_dt(value)
        return dt.isoformat() if dt else None

    def _arch_mh_spot_symbol(ticker):
        t = str(ticker or "").upper()
        if "BTC" in t:
            return "BTC"
        if "ETH" in t:
            return "ETH"
        if "SOL" in t:
            return "SOL"
        return None

    def _arch_mh_extract_rows(result):
        if isinstance(result, list):
            return result
        if isinstance(result, tuple):
            for item in result:
                if isinstance(item, list):
                    return item
                if isinstance(item, dict) and isinstance(item.get("markets"), list):
                    return item.get("markets")
        if isinstance(result, dict):
            if isinstance(result.get("markets"), list):
                return result.get("markets")
            if isinstance(result.get("data"), list):
                return result.get("data")
        return []

    def _arch_mh_cached_tickers(self_ref):
        vals = getattr(self_ref, "cached_crypto_tickers", None) or []
        out = []
        for item in vals:
            if isinstance(item, str):
                out.append(item)
            elif isinstance(item, (list, tuple)) and item:
                out.append(str(item[0]))
            elif isinstance(item, dict) and item.get("ticker"):
                out.append(str(item.get("ticker")))
        return out

    def _arch_mh_fetch_raw_markets(self_ref):
        _arch_mh_stats["fetch_attempts"] += 1

        methods = []
        if hasattr(self_ref, "_fetch_cached_crypto_markets"):
            methods.append("_fetch_cached_crypto_markets")
        if hasattr(self_ref, "refresh_markets"):
            methods.append("refresh_markets")

        tickers = _arch_mh_cached_tickers(self_ref)

        for method_name in methods:
            fn = getattr(self_ref, method_name, None)
            if not callable(fn):
                continue

            # Try no-arg call first.
            try:
                result = fn()
                rows = _arch_mh_extract_rows(result)
                rows = [r for r in rows if isinstance(r, dict) and r.get("ticker")]
                if rows:
                    _arch_mh_stats["fetch_success"] += 1
                    _arch_mh_stats["method_last"] = method_name

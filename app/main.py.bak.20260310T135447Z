    def _arch_fmt_method_candidates(self_ref):
        preferred = [
            "refresh_markets",
            "_fetch_cached_crypto_markets",
            "fetch_markets",
            "_refresh_markets",
            "_load_markets",
            "load_markets",
            "discover_markets",
            "refresh_watchlist",
        ]
        seen = set()
        out = []

        for name in preferred + sorted(dir(self_ref)):
            if name in seen:
                continue
            seen.add(name)
            if name.startswith("__"):
                continue
            fn = getattr(self_ref, name, None)
            if not callable(fn):
                continue
            lname = name.lower()
            if "market" in lname and any(x in lname for x in ("refresh", "fetch", "load", "discover", "list")):
                out.append((name, fn))
        return out[:20]

    def _arch_fmt_call_noarg(fn):
        try:
            sig = _inspect.signature(fn)
            params = [
                p for p in sig.parameters.values()
                if p.kind in (p.POSITIONAL_ONLY, p.POSITIONAL_OR_KEYWORD)
            ]
            required = [p for p in params if p.default is p.empty]
            if len(required) == 0:
                return fn(), "no_arg"
            return None, "requires_args"
        except Exception:
            return fn(), "best_effort"

    def _arch_fmt_discover_future_rows(self_ref):
        _arch_fmt_stats["discovery_attempts"] += 1
        now = _arch_dt.now(_arch_tz.utc)
        latest_close = None

        # First check existing snapshots directly.
        snap_rows = _arch_fmt_snapshot_rows(self_ref)
        if snap_rows:
            future = [r for r in snap_rows if _arch_fmt_is_active_future(r, now)]
            closes = [_arch_fmt_row_close(r) for r in snap_rows]
            closes = [c for c in closes if c is not None]
            latest_close = max(closes).isoformat() if closes else None
            if future:
                _arch_fmt_stats["discovery_success"] += 1
                _arch_fmt_stats["source_last"] = "existing_snapshots"
                _arch_fmt_stats["method_last"] = "existing_snapshots"
                _arch_fmt_stats["active_count_last"] = len(future)
                _arch_fmt_stats["latest_close_time_last"] = latest_close
                return future, latest_close

        for method_name, fn in _arch_fmt_method_candidates(self_ref):
            try:
                result, mode = _arch_fmt_call_noarg(fn)
                rows = _arch_fmt_extract_rows(result)
                if not rows:
                    rows = _arch_fmt_snapshot_rows(self_ref)

                normalized = []
                for row in rows:
                    if not isinstance(row, dict):

    def _sb2_variant_summary(trades):
        out = {}
        for t in trades or []:
            vn = str(t.get("variant_name") or "unknown")
            row = out.setdefault(vn, {
                "trades": 0,
                "closed": 0,
                "wins": 0,
                "losses": 0,
                "flat": 0,
                "realized_pnl": 0.0,
                "_entry_price_sum": 0.0,
                "_entry_edge_sum": 0.0,
                "_entry_count": 0,
            })
            row["trades"] += 1
            if t.get("closed_at"):
                row["closed"] += 1
            pnl = _sb2_safe_float(t.get("realized_pnl"), 0.0) or 0.0
            row["realized_pnl"] += pnl
            if pnl > 0:
                row["wins"] += 1
            elif pnl < 0:
                row["losses"] += 1
            elif t.get("closed_at"):
                row["flat"] += 1

            ep = _sb2_safe_float(t.get("entry_price"), None)
            ee = _sb2_safe_float(t.get("edge_at_entry"), None)
            if ep is not None:
                row["_entry_price_sum"] += ep
                row["_entry_count"] += 1
            if ee is not None:
                row["_entry_edge_sum"] += ee

        for _, row in out.items():
            denom = row["_entry_count"] or 0
            cd = row["wins"] + row["losses"] + row["flat"]
            row["avg_entry_price"] = round((row["_entry_price_sum"] / denom), 6) if denom else None
            row["avg_entry_edge"] = round((row["_entry_edge_sum"] / denom), 6) if denom else None
            row["win_rate_closed"] = round((row["wins"] / cd), 4) if cd else None
            row["realized_pnl"] = round(row["realized_pnl"], 6)
            del row["_entry_price_sum"]
            del row["_entry_edge_sum"]
            del row["_entry_count"]
        return out


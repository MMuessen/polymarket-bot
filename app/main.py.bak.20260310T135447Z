    def _arch_v16_db_path():
        candidates = [
            _ArchPathV16("data/strategy_lab.db"),
            _ArchPathV16("/app/data/strategy_lab.db"),
        ]
        for p in candidates:
            if p.exists():
                return p
        return candidates[0]

    def _arch_v16_parse_dt(v):
        if v is None:
            return None
        if isinstance(v, _arch_dt_v16):
            dt = v
        else:
            try:
                dt = _arch_dt_v16.fromisoformat(str(v).replace("Z", "+00:00"))
            except Exception:
                return None
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=_arch_tz_v16.utc)
        return dt

    def _arch_v16_count(conn, table):
        try:
            return int(conn.execute(f"SELECT COUNT(*) FROM {table}").fetchone()[0])
        except Exception:
            return None

    def _arch_v16_cols(conn, table):
        try:
            return [r[1] for r in conn.execute(f"PRAGMA table_info({table})").fetchall()]
        except Exception:
            return []

    def _arch_v16_recent_rows(conn, table, limit=5):
        cols = _arch_v16_cols(conn, table)
        if not cols:
            return []

        order_col = None
        for c in ("opened_at", "closed_at", "created_at", "updated_at", "timestamp", "ts", "id"):
            if c in cols:
                order_col = c
                break
        if order_col is None:
            return []

        wanted = [c for c in (
            "id", "ticker", "side", "status", "variant_name", "strategy_name",
            "opened_at", "closed_at", "entry_price", "exit_price", "realized_pnl",
            "unrealized_pnl", "outcome"
        ) if c in cols]
        select_cols = ", ".join(wanted) if wanted else "*"

        try:
            rows = conn.execute(
                f"SELECT {select_cols} FROM {table} ORDER BY {order_col} DESC LIMIT ?",
                (limit,)
            ).fetchall()
            out = []
            for row in rows:
                if wanted:
                    out.append({wanted[i]: row[i] for i in range(len(wanted))})
            return out
        except Exception:
            return []

    def _arch_v16_recent_opens(conn, minutes=30):
        cols = _arch_v16_cols(conn, "shadow_positions")
        if not cols or "opened_at" not in cols:
            return {"count": None, "samples": []}
        cutoff = (_arch_dt_v16.now(_arch_tz_v16.utc) - _arch_td_v16(minutes=minutes)).isoformat()
        wanted = [c for c in ("ticker", "side", "opened_at", "entry_price", "variant_name", "strategy_name") if c in cols]
        try:
            rows = conn.execute(
                f"SELECT {', '.join(wanted)} FROM shadow_positions WHERE opened_at >= ? ORDER BY opened_at DESC LIMIT 10",
                (cutoff,)
            ).fetchall()
            return {
                "count": len(rows),
                "samples": [{wanted[i]: row[i] for i in range(len(wanted))} for row in rows]
            }
        except Exception:
            return {"count": None, "samples": []}


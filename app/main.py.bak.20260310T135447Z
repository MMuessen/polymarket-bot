        _wrapped._architect_wrapped_ie_v5 = True
        _wrapped._architect_wrapped_owner = owner_label
        _wrapped._architect_wrapped_name = method_name
        _wrapped.__name__ = getattr(orig_fn, "__name__", method_name)

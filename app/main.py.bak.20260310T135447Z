                )[:20]

                if decision["would_allow_relief"]:
                    _arch_itr_v13_stats["relief_allowed"] += 1
                    return True

                _arch_itr_v13_stats["relief_blocked"] += 1
                for reason in decision["relief_reasons"]:
                    _arch_itr_v13_stats["blocked_by_reason"][reason] = (
                        _arch_itr_v13_stats["blocked_by_reason"].get(reason, 0) + 1
                    )
                return base
            except Exception as e:
                _arch_itr_v13_stats["last_error"] = repr(e)
                return base

        TradingBot._is_shadow_candidate = _arch_itr_v13_is_shadow_candidate

    _arch_itr_v13_prev_dashboard_status = getattr(TradingBot, "dashboard_status", None)
    if callable(_arch_itr_v13_prev_dashboard_status):

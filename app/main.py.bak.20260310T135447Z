        no_bid = _arch_mh_safe_float(raw.get("no_bid"), 0.0)
        no_ask = _arch_mh_safe_float(raw.get("no_ask"), 0.0)
        last_price = _arch_mh_safe_float(raw.get("last_price"), 0.0)

        # Convert cent-style prices to dollars if needed.
        if max(yes_bid, yes_ask, no_bid, no_ask, last_price, 0.0) > 1.0:
            yes_bid /= 100.0
            yes_ask /= 100.0
            no_bid /= 100.0
            no_ask /= 100.0
            last_price /= 100.0

        spread_candidates = []
        if yes_ask and yes_bid >= 0:
            spread_candidates.append(max(0.0, yes_ask - yes_bid))
        if no_ask and no_bid >= 0:
            spread_candidates.append(max(0.0, no_ask - no_bid))
        spread = min(spread_candidates) if spread_candidates else 0.0

        raw_close = raw.get("close_time") or raw.get("expiration_time") or raw.get("latest_expiration_time")
        close_dt = _arch_mh_parse_dt(raw_close)
        close_iso = close_dt.isoformat() if close_dt else None

        yes_mid = (yes_bid + yes_ask) / 2.0 if yes_ask or yes_bid else last_price
        no_mid = (no_bid + no_ask) / 2.0 if no_ask or no_bid else max(0.0, 1.0 - yes_mid)

        best_side = "yes" if yes_mid <= no_mid else "no"
        best_exec_edge = 0.0

        return _ArchHydrationSnapshotAdapter({
            "ticker": ticker,
            "title": raw.get("title"),
            "subtitle": raw.get("subtitle") or raw.get("yes_sub_title") or raw.get("no_sub_title"),

            "order_book_imbalance", "maker_toxicity_bps_1s", "cluster_bias_same_side",
            "live_executable_row", "fair_yes", "fair_yes_live_v20", "probability",
        }

        try:
            if obj is None:
                return {}
            if isinstance(obj, dict):
                return dict(obj)
            try:
                d = dict(obj)
                if isinstance(d, dict):
                    return d
            except Exception:
                pass
            try:
                if hasattr(obj, "to_dict") and callable(obj.to_dict):
                    d = obj.to_dict()
                    if isinstance(d, dict):
                        return dict(d)
            except Exception:
                pass
            try:
                if hasattr(obj, "keys"):
                    d = {k: obj[k] for k in list(obj.keys())}
                    if isinstance(d, dict):
                        return d
            except Exception:
                pass
            try:
                if hasattr(obj, "__dict__"):
                    d = {k: v for k, v in vars(obj).items() if not str(k).startswith("_")}
                    if isinstance(d, dict) and any(k in d for k in likely):
                        return d
            except Exception:
                pass
        except Exception:
            pass

        return {}

    def _arch_icrp_v26b_pick_args(args, kwargs):
        row = kwargs.get("row", None)
        preferred_side = str(
            kwargs.get("preferred_side", kwargs.get("side", "yes"))
        ).strip().lower()

        if preferred_side not in {"yes", "no"}:
            preferred_side = "yes"

        if row is None:
            for a in args:
                try:
                    if isinstance(a, str):
                        side_guess = a.strip().lower()
                        if side_guess in {"yes", "no"}:
                            preferred_side = side_guess
                        continue
                    d = _arch_icrp_v26b_rowlike_dict(a)
                    if isinstance(d, dict) and d:
                        row = a
                        break
                except Exception:
                    pass

        return row, preferred_side

    def _arch_icrp_v17_normalize(*args, **kwargs):
        row, preferred_side = _arch_icrp_v26b_pick_args(args, kwargs)
        raw = _arch_icrp_v26b_rowlike_dict(row)

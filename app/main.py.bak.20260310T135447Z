    def _sb_safe_float(v, default=None):
        try:
            if v in (None, "", "None"):
                return default
            return float(v)
        except Exception:
            return default

    def _sb_safe_int(v, default=0):
        try:
            if v in (None, "", "None"):
                return default
            return int(v)
        except Exception:
            return default

    def _sb_safe_read(path, max_chars=180000):
        try:
            p = _sb_Path(path)
            if not p.exists():
                return {
                    "path": str(path),
                    "exists": False,
                    "chars": 0,
                    "truncated": False,
                    "text": None,
                }
            text = p.read_text(encoding="utf-8", errors="ignore")
            return {
                "path": str(path),
                "exists": True,
                "chars": len(text),
                "truncated": len(text) > max_chars,
                "text": text[:max_chars],
            }
        except Exception as e:
            return {
                "path": str(path),
                "exists": False,
                "chars": 0,
                "truncated": False,
                "error": repr(e),
                "text": None,
            }

    def _sb_parse_meta(meta_json):
        if not meta_json:
            return {}
        try:
            return _sb_json.loads(meta_json)
        except Exception:
            return {}

    def _sb_table_exists(conn, name):
        try:
            row = conn.execute(
                "SELECT name FROM sqlite_master WHERE type='table' AND name = ?",
                (name,),
            ).fetchone()
            return row is not None
        except Exception:
            return False

    def _sb_rows_to_dicts(rows):
        out = []
        for row in rows or []:
            try:
                out.append(dict(row))
            except Exception:
                try:
                    out.append({k: row[k] for k in row.keys()})
                except Exception:
                    pass
        return out

    def _sb_query_rows(conn, query, args=()):
        try:
            return _sb_rows_to_dicts(conn.execute(query, args).fetchall())
        except Exception:
            return []

    def _sb_callable_info(fn):
        if not callable(fn):
            return None
        try:
            return {
                "name": getattr(fn, "__name__", None),
                "module": getattr(fn, "__module__", None),
                "qualname": getattr(fn, "__qualname__", None),
            }
        except Exception:

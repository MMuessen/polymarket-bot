        elif side == "no" and obi > 0.50:
            reason = "obi_against_no"
        elif vpin_like > 0.60 and edge < 0.05:
            reason = "toxic_flow_filter"
        elif side == "yes" and cluster_inventory >= 300:
            reason = "inventory_cap_yes"
        elif side == "no" and cluster_inventory <= -300:
            reason = "inventory_cap_no"

        meta = {
            "side": side,
            "entry_price": round(float(entry_price), 4),
            "fair_yes": round(float(fair_yes), 4),
            "fair_side": round(float(fair_side), 4),
            "edge": round(float(edge), 4),

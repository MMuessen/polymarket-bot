                        normalized.append(row)
                    elif row.get("ticker"):
                        normalized.append(_arch_fmt_normalize_row(row))

                closes = [_arch_fmt_row_close(r) for r in normalized]
                closes = [c for c in closes if c is not None]
                latest_close = max(closes).isoformat() if closes else latest_close

                future = [r for r in normalized if _arch_fmt_is_active_future(r, now)]
                if future:
                    _arch_fmt_stats["discovery_success"] += 1
                    _arch_fmt_stats["source_last"] = "method"
                    _arch_fmt_stats["method_last"] = f"{method_name}:{mode}"
                    _arch_fmt_stats["active_count_last"] = len(future)
                    _arch_fmt_stats["latest_close_time_last"] = latest_close
                    return future, latest_close
            except Exception as e:
                _arch_fmt_stats["last_error"] = repr(e)

        _arch_fmt_stats["source_last"] = "none"
        _arch_fmt_stats["method_last"] = None
        _arch_fmt_stats["active_count_last"] = 0

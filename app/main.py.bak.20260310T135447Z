    }

    _aqg_stats.setdefault("data_truth_v47", {
        "config": dict(_AQG_V47),
        "runs": 0,
        "queued": 0,
        "fills": 0,
        "cancels": 0,
        "queue_size": 0,
        "pending_orders": [],
        "fill_samples": [],
        "cancel_samples": [],
        "attempt_samples": [],
        "last_error": None,
    })

    def _v47_float(v, default=None):
        try:
            if v in (None, "", "None"):
                return default
            return float(v)
        except Exception:
            return default

    def _v47_push(bucket, item, limit=100):
        try:
            arr = _aqg_stats["data_truth_v47"].setdefault(bucket, [])
            arr.append(dict(item))
            _aqg_stats["data_truth_v47"][bucket] = arr[-limit:]
        except Exception:
            pass

    def _v47_now():
        return float(_v47_time.time())

    def _v47_side(snapshot):
        try:
            return str(
                getattr(snapshot, "best_side",
                    getattr(snapshot, "side",
                        getattr(snapshot, "direction_signal",
                            getattr(snapshot, "direction", "yes")
                        )
                    )
                ) or "yes"
            ).lower()
        except Exception:
            return "yes"

    def _v47_set_side(snapshot, side):
        for attr in ("best_side", "side", "direction_signal", "direction"):
            try:
                setattr(snapshot, attr, side)
            except Exception:
                pass

    def _v47_ask(snapshot, side):
        if str(side).lower() == "no":
            return _v47_float(getattr(snapshot, "no_ask", None), None)
        return _v47_float(getattr(snapshot, "yes_ask", None), None)

    def _v47_key(ticker, variant_name):
        return f"{ticker}::{variant_name}"

    def _v47_pending_map(self):
        pm = getattr(self, "_architect_pending_v47", None)
        if pm is None or not isinstance(pm, dict):
            pm = {}
            try:
                setattr(self, "_architect_pending_v47", pm)
            except Exception:
                pass
        return pm

    def _v47_sync_pending_stats(self):
        try:
            pm = _v47_pending_map(self)
            _aqg_stats["data_truth_v47"]["queue_size"] = len(pm)
            _aqg_stats["data_truth_v47"]["pending_orders"] = list(pm.values())[-40:]
        except Exception:
            pass

    try:
        from app.strategy_lab.config import DEFAULT_VARIANTS as _V47_DEFAULT_VARIANTS
    except Exception:
        _V47_DEFAULT_VARIANTS = {
            "crypto_lag_conservative": {},
            "crypto_lag_adaptive": {},
            "crypto_lag_aggressive": {},
        }

    _SE = globals().get("ShadowEngine", None)
    if _SE is None:
        from app.strategy_lab.shadow_engine import ShadowEngine as _SE  # type: ignore

    _prev_run_shadow_variants_v47 = getattr(_SE, "run_shadow_variants", None)
    if callable(_prev_run_shadow_variants_v47) and not getattr(_prev_run_shadow_variants_v47, "_architect_paper_maker_v47_wrapped", False):
        def _aqg_run_shadow_variants_v47(self, *args, **kwargs):
            try:
                _aqg_stats["data_truth_v47"]["runs"] = int(_aqg_stats["data_truth_v47"].get("runs", 0) or 0) + 1
                _aqg_stats["data_truth_v47"]["config"] = dict(_AQG_V47)
            except Exception:
                pass

            regime_name = getattr(self.bot, "current_regime", "conservative")

            try:
                if hasattr(self, "mark_positions"):
                    self.mark_positions()
            except Exception as e:
                _aqg_stats["data_truth_v47"]["last_error"] = repr(e)

            try:
                if hasattr(self, "run_exit_pass"):
                    self.run_exit_pass()
            except Exception as e:
                _aqg_stats["data_truth_v47"]["last_error"] = repr(e)

            try:
                store = self._market_store() or {}
            except Exception as e:
                _aqg_stats["data_truth_v47"]["last_error"] = repr(e)
                store = {}

            pm = _v47_pending_map(self)
            now_ts = _v47_now()

            # --- first, try to fill pending maker orders ---
            for key, order in list(pm.items()):
                ticker = order.get("ticker")
                variant_name = order.get("variant_name")
                snapshot = (store or {}).get(ticker)

                if snapshot is None:
                    if (now_ts - float(order.get("created_ts", now_ts))) >= _AQG_V47["max_wait_seconds"]:
                        order["final"] = "cancel_timeout_no_snapshot"
                        _v47_push("cancel_samples", order)
                        pm.pop(key, None)
                        _aqg_stats["data_truth_v47"]["cancels"] = int(_aqg_stats["data_truth_v47"].get("cancels", 0) or 0) + 1
                    continue

                try:
                    self.bot._enrich_with_fair_value(snapshot)
                except Exception:
                    pass

                ok, reason = self._passes_variant_rules(snapshot, variant_name)
                current_side = _v47_side(snapshot)

                if (not ok) or (current_side != order.get("side")):
                    cancel = dict(order)
                    cancel["final"] = "cancel_gate_changed"
                    cancel["gate_ok"] = bool(ok)
                    cancel["gate_reason"] = reason
                    cancel["current_side"] = current_side
                    _v47_push("cancel_samples", cancel)
                    pm.pop(key, None)
                    _aqg_stats["data_truth_v47"]["cancels"] = int(_aqg_stats["data_truth_v47"].get("cancels", 0) or 0) + 1
                    continue

                current_ask = _v47_ask(snapshot, order.get("side"))
                target_price = _v47_float(order.get("target_price"), None)

                if current_ask is not None and target_price is not None and current_ask <= target_price:
                    try:
                        _v47_set_side(snapshot, order.get("side"))
                    except Exception:
                        pass

                    dollars = _v47_float(order.get("dollars"), _AQG_V47["default_ticket_dollars"]) or _AQG_V47["default_ticket_dollars"]
                    qty = max(int(dollars / max(target_price, 0.01)), 1)

                    fill = dict(order)
                    fill["fill_current_ask"] = current_ask
                    fill["qty"] = qty

                    try:
                        opened = self.open_shadow_trade(variant_name, snapshot, qty, target_price, regime_name)
                        fill["opened"] = bool(opened)
                        fill["final"] = "filled" if opened else "fill_returned_false"
                        if opened:
                            _aqg_stats["data_truth_v47"]["fills"] = int(_aqg_stats["data_truth_v47"].get("fills", 0) or 0) + 1
                            pm.pop(key, None)
                        else:
                            pm.pop(key, None)
                            _aqg_stats["data_truth_v47"]["cancels"] = int(_aqg_stats["data_truth_v47"].get("cancels", 0) or 0) + 1
                    except Exception as e:
                        fill["opened"] = False
                        fill["final"] = "fill_exception"
                        fill["error"] = repr(e)
                        _aqg_stats["data_truth_v47"]["last_error"] = repr(e)
                        pm.pop(key, None)
                        _aqg_stats["data_truth_v47"]["cancels"] = int(_aqg_stats["data_truth_v47"].get("cancels", 0) or 0) + 1

                    _v47_push("fill_samples", fill)
                    continue

                if (now_ts - float(order.get("created_ts", now_ts))) >= _AQG_V47["max_wait_seconds"]:
                    cancel = dict(order)
                    cancel["final"] = "cancel_timeout_unfilled"
                    cancel["last_seen_ask"] = current_ask
                    _v47_push("cancel_samples", cancel)
                    pm.pop(key, None)
                    _aqg_stats["data_truth_v47"]["cancels"] = int(_aqg_stats["data_truth_v47"].get("cancels", 0) or 0) + 1

            _v47_sync_pending_stats(self)

            # --- second, queue new maker orders instead of taking the ask ---
            for ticker, snapshot in list((store or {}).items()):
                try:
                    self.bot._enrich_with_fair_value(snapshot)
                except Exception:
                    pass

                for variant_name in (_V47_DEFAULT_VARIANTS or {}):
                    attempt = {
                        "ticker": getattr(snapshot, "ticker", ticker),
                        "variant_name": variant_name,
                    }

                    try:
                        if hasattr(self, "_already_open") and self._already_open(getattr(snapshot, "ticker", ticker), variant_name):
                            attempt["final"] = "skip_already_open"
                            _v47_push("attempt_samples", attempt)
                            continue
                    except Exception:
                        pass

                    if variant_name != _AQG_V47["only_variant"]:
                        attempt["final"] = "skip_non_aggressive_variant"
                        _v47_push("attempt_samples", attempt)
                        continue

                    key = _v47_key(getattr(snapshot, "ticker", ticker), variant_name)
                    if key in pm:
                        attempt["final"] = "skip_pending_exists"
                        _v47_push("attempt_samples", attempt)
                        continue

                    ok, reason = self._passes_variant_rules(snapshot, variant_name)
                    attempt["gate_ok"] = bool(ok)
                    attempt["gate_reason"] = reason
                    attempt["side"] = _v47_side(snapshot)

                    if not ok:
                        attempt["final"] = "skip_variant_rules"
                        _v47_push("attempt_samples", attempt)
                        continue

                    side = _v47_side(snapshot)
                    ask = _v47_ask(snapshot, side)
                    attempt["ask"] = ask

                    if ask is None or ask <= 0:
                        attempt["final"] = "skip_missing_side_ask"
                        _v47_push("attempt_samples", attempt)
                        continue

                    target_price = round(max(0.01, ask - _AQG_V47["price_improve"]), 2)
                    if target_price >= ask:
                        attempt["final"] = "skip_no_improvement_room"
                        attempt["target_price"] = target_price
                        _v47_push("attempt_samples", attempt)
                        continue

                    dollars = _AQG_V47["default_ticket_dollars"]
                    try:
                        st = getattr(self.bot, "strategy_states", {}).get(variant_name)
                        dollars = _v47_float(getattr(st, "max_ticket_dollars", None), dollars) or dollars
                    except Exception:
                        pass

                    order = {
                        "ticker": getattr(snapshot, "ticker", ticker),
                        "variant_name": variant_name,
                        "side": side,
                        "ask_at_queue": ask,

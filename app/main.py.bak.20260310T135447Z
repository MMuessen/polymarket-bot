        prev_px = None
        for ts, px in reversed(hist[:-1]):
            if now_ts - ts >= 1.0:
                prev_px = px
                break
        if prev_px is None or prev_px <= 0:
            return 0.0
        return ((now_px - prev_px) / prev_px) * 10000.0


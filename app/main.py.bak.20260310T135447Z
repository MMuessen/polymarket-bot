    def _arch_iq_hotfix_vpin_like(snapshot):
        tape_imb = abs(_arch_iq_hotfix_safe_float(_arch_iq_hotfix_field(snapshot, "trade_tape_imbalance_15m", None), 0.0))
        whale = int(_arch_iq_hotfix_safe_float(_arch_iq_hotfix_field(snapshot, "whale_flag", None), 0.0))

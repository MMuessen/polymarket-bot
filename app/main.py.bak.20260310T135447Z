                out.get("maker_best_side"),
                out.get("taker_best_side"),
                out.get("side"),
                out.get("entry_side"),
                preferred_side,
                default="yes",
            )
        ).strip().lower()

        if side not in {"yes", "no"}:
            side = preferred_side if preferred_side in {"yes", "no"} else "yes"

        yes_bid = _arch_icrp_v26b_float(
            _arch_icrp_v26b_first(out.get("yes_bid"), out.get("bid_yes")),

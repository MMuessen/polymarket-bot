        ask = _arch_iq_side_ask(snapshot, side)
        fair_side = fair_yes if side == "yes" else (1.0 - fair_yes)
        fee = _arch_iq_safe_float(_arch_iq_field(snapshot, "taker_fee_estimate", None), 0.0)
        return float(fair_side - ask - fee)

    def _arch_iq_best_side(self_ref, snapshot, fair_yes=None):
        if fair_yes is None:
            fair_yes = _arch_iq_bucket_fair_yes(self_ref, snapshot)
        yes_edge = _arch_iq_side_edge(self_ref, snapshot, "yes", fair_yes=fair_yes)
        no_edge = _arch_iq_side_edge(self_ref, snapshot, "no", fair_yes=fair_yes)
        if no_edge > yes_edge:

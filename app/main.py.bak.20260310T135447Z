        return 0.0

    def _arch_iq_hotfix_obi(snapshot, side):
        raw = _arch_iq_hotfix_raw(snapshot)
        if side == "yes":
            bid = _arch_iq_hotfix_safe_float(raw.get("yes_bid_size_fp") or _arch_iq_hotfix_field(snapshot, "yes_bid_size_fp", None), 0.0)
            ask = _arch_iq_hotfix_safe_float(raw.get("yes_ask_size_fp") or _arch_iq_hotfix_field(snapshot, "yes_ask_size_fp", None), 0.0)
        else:
            bid = _arch_iq_hotfix_safe_float(raw.get("no_bid_size_fp") or _arch_iq_hotfix_field(snapshot, "no_bid_size_fp", None), 0.0)
            ask = _arch_iq_hotfix_safe_float(raw.get("no_ask_size_fp") or _arch_iq_hotfix_field(snapshot, "no_ask_size_fp", None), 0.0)

        if (bid + ask) > 0:
            return max(-1.0, min((bid - ask) / (bid + ask), 1.0))

        obi = _arch_iq_hotfix_field(snapshot, "order_book_imbalance", None)
        if obi is not None:
            return max(-1.0, min(_arch_iq_hotfix_safe_float(obi, 0.0), 1.0))

        tape = _arch_iq_hotfix_field(snapshot, "trade_tape_imbalance_15m", None)
        if tape is not None:
            return max(-1.0, min(_arch_iq_hotfix_safe_float(tape, 0.0), 1.0))


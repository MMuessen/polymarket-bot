    def _arch_qp_call_header_builder(fn, method, req_path):
        attempts = [
            (method, req_path),
            (method, req_path, ""),
            (req_path, method),
            (req_path,),
        ]
        for args in attempts:
            try:
                out = fn(*args)
                if isinstance(out, dict) and out:
                    return out
            except TypeError:
                continue
            except Exception:
                continue
        return None

    def _arch_qp_find_signed_headers(self_ref, method, req_path):
        _arch_qp_stats["signed_header_attempts"] += 1

        candidates = [
            self_ref,
            getattr(self_ref, "kalshi_client", None),
            getattr(self_ref, "client", None),
            getattr(self_ref, "api", None),
            getattr(self_ref, "exchange_client", None),
        ]
        method_names = [
            "_kalshi_auth_headers",
            "_build_kalshi_auth_headers",
            "_build_auth_headers",
            "_auth_headers",
            "_signed_headers",
            "_sign_headers",
            "_request_headers",
        ]

        for obj in candidates:
            if obj is None:
                continue
            for name in method_names:
                fn = getattr(obj, name, None)
                if callable(fn):
                    hdrs = _arch_qp_call_header_builder(fn, method, req_path)
                    if isinstance(hdrs, dict) and hdrs:
                        lk = {str(k).lower(): v for k, v in hdrs.items()}
                        if any(k in lk for k in (
                            "kalshi-access-key",
                            "authorization",
                            "kalshi-access-signature",
                        )):
                            _arch_qp_stats["signed_header_source_last"] = f"{type(obj).__name__}.{name}"
                            return hdrs

        raise RuntimeError("No callable Kalshi auth-header builder found on bot/client objects")


    def _sb_variant_summary(trades):
        out = {}
        for t in trades or []:
            vn = str(t.get("variant_name") or "unknown")
            row = out.setdefault(vn, {
                "trades": 0,
                "closed": 0,
                "wins": 0,
                "losses": 0,
                "flat": 0,
                "realized_pnl": 0.0,
                "_entry_price_sum": 0.0,
                "_entry_edge_sum": 0.0,
                "_entry_count": 0,
            })
            row["trades"] += 1
            if t.get("closed_at"):
                row["closed"] += 1
            outcome = str(t.get("outcome") or "").lower()
            if outcome == "win":
                row["wins"] += 1
            elif outcome == "loss":
                row["losses"] += 1
            elif outcome == "flat":
                row["flat"] += 1
            pnl = _sb_safe_float(t.get("realized_pnl"), 0.0) or 0.0
            row["realized_pnl"] += pnl
            ep = _sb_safe_float(t.get("entry_price"), None)
            ee = _sb_safe_float(t.get("edge_at_entry"), None)
            if ep is not None:
                row["_entry_price_sum"] += ep
                row["_entry_count"] += 1
            if ee is not None:
                row["_entry_edge_sum"] += ee

        for vn, row in out.items():
            denom = row["_entry_count"] or 0
            closed_denom = row["wins"] + row["losses"] + row["flat"]
            row["avg_entry_price"] = round((row["_entry_price_sum"] / denom), 6) if denom else None
            row["avg_entry_edge"] = round((row["_entry_edge_sum"] / denom), 6) if denom else None
            row["win_rate_closed"] = round((row["wins"] / closed_denom), 4) if closed_denom else None
            row["realized_pnl"] = round(row["realized_pnl"], 6)
            del row["_entry_price_sum"]
            del row["_entry_edge_sum"]
            del row["_entry_count"]
        return out

    def _sb_postmortem(trades):
        by_close_reason = {}
        by_variant = {}
        for t in trades or []:
            pnl = _sb_safe_float(t.get("realized_pnl"), 0.0) or 0.0
            cr = str(t.get("close_reason") or "open_or_unknown")
            vn = str(t.get("variant_name") or "unknown")

            a = by_close_reason.setdefault(cr, {"count": 0, "pnl": 0.0})
            a["count"] += 1
            a["pnl"] += pnl

            b = by_variant.setdefault(vn, {"count": 0, "pnl": 0.0})
            b["count"] += 1
            b["pnl"] += pnl

        for d in [by_close_reason, by_variant]:
            for _, row in d.items():
                row["pnl"] = round(row["pnl"], 6)

        return {
            "by_close_reason": by_close_reason,
            "by_variant": by_variant,
        }


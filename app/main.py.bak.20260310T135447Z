# --- architect institutional throughput relief v12 ---
try:
    import sqlite3 as _arch_sqlite3_v12
    from pathlib import Path as _ArchPathV12
    from fastapi.responses import JSONResponse

    _architect_institutional_throughput_relief_v12_applied = True

    _arch_itr_v12_stats = {
        "dashboard_attaches": 0,
        "candidate_calls": 0,
        "base_allowed": 0,
        "hydrate_hits": 0,
        "hydrate_misses": 0,
        "relief_allowed": 0,
        "relief_blocked": 0,
        "blocked_by_reason": {},
        "last_error": None,
        "last_samples": [],
    }

    def _arch_itr_v12_route_exists(path):
        try:
            return any(getattr(r, "path", None) == path for r in app.router.routes)
        except Exception:
            return False

    def _arch_itr_v12_safe_float(v, default=0.0):
        try:
            if v is None:
                return default
            if isinstance(v, str) and not v.strip():
                return default
            return float(v)
        except Exception:
            return default

    def _arch_itr_v12_ticker_from_snapshot(snapshot):
        try:
            if isinstance(snapshot, dict):
                return snapshot.get("ticker")
            return getattr(snapshot, "ticker", None)
        except Exception:
            return None

    def _arch_itr_v12_db_path():
        return _ArchPathV12("data/strategy_lab.db")

    def _arch_itr_v12_latest_row_for_ticker(ticker):
        db = _arch_itr_v12_db_path()
        if not ticker or not db.exists():
            return {}

        wanted = [
            "ticker",
            "best_side",
            "maker_side",
            "side",
            "yes_ask",
            "no_ask",
            "spread",
            "order_book_imbalance",
            "maker_toxicity_bps_1s",
            "cluster_bias_same_side",
            "maker_edge_after_rebate_and_inventory",
            "maker_edge_after_rebate",
            "best_exec_edge",
            "id",
        ]

        for table in ("market_opportunities", "execution_compare_cohorts", "candidate_events"):
            try:
                conn = _arch_sqlite3_v12.connect(str(db))
                conn.row_factory = _arch_sqlite3_v12.Row
                cols = [r[1] for r in conn.execute(f"PRAGMA table_info({table})").fetchall()]
                have = [c for c in wanted if c in cols]
                if "ticker" not in have:
                    conn.close()
                    continue
                order_col = "id" if "id" in cols else "rowid"
                q = f"""
                    SELECT {", ".join(have)}
                    FROM {table}
                    WHERE ticker = ?
                    ORDER BY {order_col} DESC
                    LIMIT 1
                """
                row = conn.execute(q, (ticker,)).fetchone()
                conn.close()
                if row:
                    out = dict(row)
                    out["_table"] = table
                    return out
            except Exception:
                try:
                    conn.close()
                except Exception:
                    pass
                continue
        return {}

    def _arch_itr_v12_decide(row):
        side = str(
            row.get("best_side")
            or row.get("maker_side")
            or row.get("side")
            or "yes"
        ).lower()

        spread = _arch_itr_v12_safe_float(row.get("spread"), 0.0)
        obi = _arch_itr_v12_safe_float(row.get("order_book_imbalance"), 0.0)
        tox = _arch_itr_v12_safe_float(row.get("maker_toxicity_bps_1s"), 0.0)
        cluster_bias = _arch_itr_v12_safe_float(row.get("cluster_bias_same_side"), 0.0)

        edge = _arch_itr_v12_safe_float(
            row.get("maker_edge_after_rebate_and_inventory"),
            _arch_itr_v12_safe_float(
                row.get("maker_edge_after_rebate"),
                _arch_itr_v12_safe_float(row.get("best_exec_edge"), 0.0),
            ),
        )

        entry_price = None
        if side == "yes":
            entry_price = row.get("yes_ask")
        elif side == "no":
            entry_price = row.get("no_ask")

        entry_price = _arch_itr_v12_safe_float(entry_price, None)

        # controlled relief:
        # still professional, but not so tight that the bot fully starves
        if spread <= 0.02:
            required_edge = 0.015
        elif spread <= 0.03:
            required_edge = 0.020
        else:
            required_edge = 999.0

        reasons = []

        if edge < required_edge:
            reasons.append("relief_edge_below_floor")

        if tox >= 2.5:
            reasons.append("relief_toxic_fill_risk_2_5bps")

        if side == "yes" and obi < 0.05:
            reasons.append("relief_obi_not_supportive_yes")
        if side == "no" and obi > -0.05:
            reasons.append("relief_obi_not_supportive_no")

        allow = not reasons

        return {
            "ticker": row.get("ticker"),
            "table": row.get("_table"),
            "best_side": side,
            "entry_price": entry_price,
            "spread": spread,
            "order_book_imbalance": obi,
            "maker_toxicity_bps_1s": tox,
            "cluster_bias_same_side": cluster_bias,
            "edge_after_rebate_and_inventory": edge,
            "required_edge_v12": required_edge,
            "would_allow_relief": allow,
            "relief_reasons": reasons,
        }

    if hasattr(TradingBot, "_is_shadow_candidate"):
        _arch_itr_v12_prev_is_shadow_candidate = TradingBot._is_shadow_candidate

        def _arch_itr_v12_is_shadow_candidate(self, *args, **kwargs):
            _arch_itr_v12_stats["candidate_calls"] += 1
            base = _arch_itr_v12_prev_is_shadow_candidate(self, *args, **kwargs)

            try:
                if bool(base):
                    _arch_itr_v12_stats["base_allowed"] += 1
                    return base

                snapshot = None
                if args:
                    snapshot = args[0]
                elif "snapshot" in kwargs:
                    snapshot = kwargs["snapshot"]

                ticker = _arch_itr_v12_ticker_from_snapshot(snapshot)
                if not ticker:
                    _arch_itr_v12_stats["hydrate_misses"] += 1
                    return base

                row = _arch_itr_v12_latest_row_for_ticker(ticker)
                if not row:
                    _arch_itr_v12_stats["hydrate_misses"] += 1
                    return base

                _arch_itr_v12_stats["hydrate_hits"] += 1
                decision = _arch_itr_v12_decide(row)

                sample = dict(decision)
                sample["stage"] = "throughput_relief_v12"
                _arch_itr_v12_stats["last_samples"] = (
                    [sample] + _arch_itr_v12_stats["last_samples"]
                )[:20]

                if decision["would_allow_relief"]:
                    _arch_itr_v12_stats["relief_allowed"] += 1
                    return True

                _arch_itr_v12_stats["relief_blocked"] += 1
                for reason in decision["relief_reasons"]:
                    _arch_itr_v12_stats["blocked_by_reason"][reason] = (
                        _arch_itr_v12_stats["blocked_by_reason"].get(reason, 0) + 1
                    )
                return base
            except Exception as e:
                _arch_itr_v12_stats["last_error"] = repr(e)
                return base

        TradingBot._is_shadow_candidate = _arch_itr_v12_is_shadow_candidate

    _arch_itr_v12_prev_dashboard_status = getattr(TradingBot, "dashboard_status", None)
    if callable(_arch_itr_v12_prev_dashboard_status):
        def _arch_itr_v12_dashboard_status(self, *args, **kwargs):
            status = _arch_itr_v12_prev_dashboard_status(self, *args, **kwargs)
            try:
                if isinstance(status, dict):
                    status["institutional_throughput_relief_v12_present"] = True
                    status["institutional_throughput_relief_v12"] = {
                        "candidate_calls": _arch_itr_v12_stats["candidate_calls"],
                        "base_allowed": _arch_itr_v12_stats["base_allowed"],
                        "hydrate_hits": _arch_itr_v12_stats["hydrate_hits"],
                        "hydrate_misses": _arch_itr_v12_stats["hydrate_misses"],
                        "relief_allowed": _arch_itr_v12_stats["relief_allowed"],
                        "relief_blocked": _arch_itr_v12_stats["relief_blocked"],
                        "blocked_by_reason": dict(_arch_itr_v12_stats["blocked_by_reason"]),
                        "last_error": _arch_itr_v12_stats["last_error"],
                    }
                    _arch_itr_v12_stats["dashboard_attaches"] += 1
            except Exception as e:
                _arch_itr_v12_stats["last_error"] = repr(e)
            return status

        TradingBot.dashboard_status = _arch_itr_v12_dashboard_status

    async def _arch_itr_v12_report():
        return JSONResponse({
            "ok": True,
            "policy": "paper_only__institutional_throughput_relief_v12",
            "stats": dict(_arch_itr_v12_stats),
        })

    if not _arch_itr_v12_route_exists("/api/debug/institutional-funnel"):
        app.add_api_route(
            "/api/debug/institutional-funnel",

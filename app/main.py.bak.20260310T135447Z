            return default

    def _arch_icrp_v26b_truthy(v):
        try:
            if isinstance(v, str):
                return v.strip().lower() in {"1", "true", "yes", "y", "on"}
            return bool(v)
        except Exception:
            return False

    def _arch_icrp_v26b_first(*vals, default=None):
        for v in vals:
            if v is None:
                continue
            if isinstance(v, str) and not v.strip():
                continue
            return v
        return default

    def _arch_icrp_v26b_rowlike_dict(obj):
        likely = {
            "ticker", "market_ticker", "symbol", "instrument", "instrument_name",
            "__source_table", "table", "source_table",
            "best_side", "maker_best_side", "taker_best_side", "side", "entry_side",
            "yes_bid", "yes_ask", "no_bid", "no_ask",
            "entry_price", "requested_price", "simulated_fill_price", "fill_price",
            "edge_after_rebate_and_inventory", "maker_edge_after_rebate_and_inventory",

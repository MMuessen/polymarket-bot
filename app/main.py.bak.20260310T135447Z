        if fair_yes is not None and yes_ask is not None:
            yes_edge = fair_yes - yes_ask

        no_edge = None
        if fair_yes is not None and no_ask is not None:
            no_edge = (1.0 - fair_yes) - no_ask

        chosen_side = base_side
        chosen_edge = yes_edge if base_side == "yes" else no_edge


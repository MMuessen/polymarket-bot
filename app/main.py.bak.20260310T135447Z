    def _arch_iq_mark_positions(self_ref):
        conn = _arch_iq_get_conn()
        try:
            rows = conn.execute("SELECT * FROM shadow_positions").fetchall()
            for row in rows:
                rowd = _arch_iq_row_dict(row)
                snapshot = self_ref._market_store().get(rowd.get("ticker"))
                if not snapshot:
                    continue

                side = str(rowd.get("side") or "yes").lower().strip()
                if side not in {"yes", "no"}:
                    side = "yes"

                entry = _arch_iq_safe_float(rowd.get("entry_price"), 0.0)
                qty = int(_arch_iq_safe_float(rowd.get("qty"), 0.0))
                if qty <= 0:
                    continue

                bid_mark = _arch_iq_side_bid(snapshot, side)
                if bid_mark <= 0.0:
                    mid = _arch_iq_safe_float(_arch_iq_field(snapshot, "mid", None), entry)
                    bid_mark = mid if mid > 0.0 else entry

                mark = float(bid_mark or entry)
                unrealized = (mark - entry) * qty
                best_mark = max(_arch_iq_safe_float(rowd.get("best_mark_price"), mark), mark)
                worst_mark = min(_arch_iq_safe_float(rowd.get("worst_mark_price"), mark), mark)

                current_edge = _arch_iq_side_edge(self_ref, snapshot, side)
                spread_now = _arch_iq_safe_float(_arch_iq_field(snapshot, "spread", None), 0.0)

                conn.execute(
                    """
                    UPDATE shadow_positions
                    SET last_mark_price = ?, unrealized_pnl = ?, best_mark_price = ?, worst_mark_price = ?,
                        last_edge = ?, last_spread = ?
                    WHERE ticker = ? AND variant_name = ?
                    """,
                    (
                        float(mark),
                        float(unrealized),
                        float(best_mark),
                        float(worst_mark),
                        float(current_edge),
                        float(spread_now),
                        rowd.get("ticker"),
                        rowd.get("variant_name"),
                    ),
                )

                trade_row = conn.execute(
                    """
                    SELECT id, opened_at, meta_json
                    FROM shadow_trades
                    WHERE ticker = ? AND variant_name = ? AND closed_at IS NULL
                    ORDER BY id DESC
                    LIMIT 1
                    """,
                    (rowd.get("ticker"), rowd.get("variant_name")),
                ).fetchone()

                if trade_row:
                    trd = _arch_iq_row_dict(trade_row)
                    trade_id = int(_arch_iq_safe_float(trd.get("id"), 0))
                    opened_dt = _arch_iq_parse_dt(trd.get("opened_at"))
                    meta = _arch_iq_json_loads(trd.get("meta_json"))
                    spot_now = _arch_iq_spot(self_ref, snapshot)

                    if spot_now > 0 and not meta.get("fill_spot"):
                        meta["fill_spot"] = spot_now

                    if opened_dt is not None and spot_now > 0:
                        elapsed = max((_arch_iq_now() - opened_dt).total_seconds(), 0.0)
                        fill_spot = _arch_iq_safe_float(meta.get("fill_spot"), 0.0)
                        for sec in (1, 5, 10):
                            key = f"spot_t{sec}s"
                            bps_key = f"markout_{sec}s_bps"
                            if elapsed >= sec and key not in meta:
                                meta[key] = spot_now
                                if fill_spot > 0:
                                    move_bps = ((spot_now - fill_spot) / fill_spot) * 10000.0
                                    if side == "no":
                                        move_bps = -move_bps
                                    meta[bps_key] = round(float(move_bps), 2)

                    mfe = max((best_mark - entry) * qty, 0.0)
                    mae = min((worst_mark - entry) * qty, 0.0)

                    conn.execute(
                        """
                        UPDATE shadow_trades
                        SET max_favorable_excursion = ?, max_adverse_excursion = ?,
                            best_mark_price = ?, worst_mark_price = ?, edge_at_exit = ?, spread_at_exit = ?,
                            distance_from_spot_pct_at_exit = ?, meta_json = ?
                        WHERE id = ?
                        """,
                        (
                            float(mfe),
                            float(mae),
                            float(best_mark),
                            float(worst_mark),
                            float(current_edge),
                            float(spread_now),
                            float(_arch_iq_field(snapshot, "distance_from_spot_pct", 0.0) or 0.0),
                            _arch_iq_json_dumps(meta),
                            trade_id,
                        ),
                    )

            conn.commit()
            _arch_iq_stats["mark_position_passes"] += 1
        finally:
            conn.close()


                "edge_after_rebate_and_inventory": round(edge_after_rebate_and_inventory, 4),
                "would_block": bool(reasons),
                "block_reasons": reasons,
            })

        out.sort(key=lambda x: (not x["would_block"], x["entry_price"]))
        return out

    async def _arch_iegp_safe_status():

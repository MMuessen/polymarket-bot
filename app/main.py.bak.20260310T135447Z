    def _sb2_schema_for_table(conn, name):
        try:
            rows = conn.execute(f"PRAGMA table_info({name})").fetchall()
            return [
                {
                    "cid": r[0],
                    "name": r[1],
                    "type": r[2],
                    "notnull": r[3],
                    "default": r[4],
                    "pk": r[5],
                }
                for r in rows
            ]
        except Exception as e:
            return [{"error": repr(e)}]


    def _arch_icrp_v17_pick_best(ticker, preferred_side="yes"):
        rows = _arch_icrp_v17_fetch_rows(ticker)
        if not rows:
            return None

        norm = [_arch_icrp_v17_normalize(r, preferred_side=preferred_side) for r in rows]

        live_tables = {"market_opportunities", "candidate_events"}
        live_norm = [r for r in norm if r.get("table") in live_tables]

        def _score(r):
            table = r.get("table")
            table_bonus = 2.0 if table == "market_opportunities" else (1.0 if table == "candidate_events" else 0.0)
            side_bonus = 0.50 if r["best_side"] == preferred_side else 0.0
            spread_bonus = 0.20 if r["spread"] <= 0.02 else (0.10 if r["spread"] <= 0.04 else -1.0)
            tox_penalty = -2.0 if r["maker_toxicity_bps_1s"] >= 4.0 else 0.0
            return table_bonus + r["edge_after_rebate_and_inventory"] + side_bonus + spread_bonus + tox_penalty

        base = live_norm if live_norm else norm
        base.sort(key=_score, reverse=True)
        best = dict(base[0])
        best["_live_executable_row"] = best.get("table") in live_tables
        best = _arch_icrp_v19_reprice_from_live(best)
        return best


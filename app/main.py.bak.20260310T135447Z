        if max(yes_bid, yes_ask, no_bid, no_ask, last_price, 0.0) > 1.0:
            yes_bid /= 100.0
            yes_ask /= 100.0
            no_bid /= 100.0
            no_ask /= 100.0
            last_price /= 100.0

        spread_candidates = []
        if yes_ask or yes_bid:
            spread_candidates.append(max(0.0, yes_ask - yes_bid))
        if no_ask or no_bid:
            spread_candidates.append(max(0.0, no_ask - no_bid))
        spread = min(spread_candidates) if spread_candidates else 0.0

        raw_close = raw.get("close_time") or raw.get("expected_expiration_time") or raw.get("expiration_time") or raw.get("latest_expiration_time")
        close_dt = _arch_fmt_parse_dt(raw_close)
        close_iso = close_dt.isoformat() if close_dt else None

        mid_yes = (yes_bid + yes_ask) / 2.0 if (yes_bid or yes_ask) else last_price
        mid_no = (no_bid + no_ask) / 2.0 if (no_bid or no_ask) else max(0.0, 1.0 - mid_yes)

        VALUES (?, ?, ?)
        ON CONFLICT(key) DO UPDATE SET
            value_text = excluded.value_text,
            updated_at = excluded.updated_at
        """,
        (key, str(value), _mp_utc_now()),
    )
    conn.commit()

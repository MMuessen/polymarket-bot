            if isinstance(snapshot, dict):
                return snapshot.get("ticker")
            return getattr(snapshot, "ticker", None)
        except Exception:
            return None

    def _arch_itr_v13_db_path():
        return _ArchPathV13("data/strategy_lab.db")

    def _arch_itr_v13_latest_row_for_ticker(ticker):
        db = _arch_itr_v13_db_path()
        if not ticker or not db.exists():
            return {}

        wanted = [
            "ticker",
            "best_side",
            "maker_side",
            "side",
            "yes_ask",
            "no_ask",
            "spread",
            "order_book_imbalance",
            "maker_toxicity_bps_1s",
            "cluster_bias_same_side",
            "maker_edge_after_rebate_and_inventory",
            "maker_edge_after_rebate",
            "best_exec_edge",
            "id",
        ]

        for table in ("market_opportunities", "execution_compare_cohorts", "candidate_events"):
            conn = None
            try:
                conn = _arch_sqlite3_v13.connect(str(db))
                conn.row_factory = _arch_sqlite3_v13.Row
                cols = [r[1] for r in conn.execute(f"PRAGMA table_info({table})").fetchall()]
                have = [c for c in wanted if c in cols]
                if "ticker" not in have:
                    conn.close()
                    continue
                order_col = "id" if "id" in cols else "rowid"
                row = conn.execute(
                    f"SELECT {', '.join(have)} FROM {table} WHERE ticker = ? ORDER BY {order_col} DESC LIMIT 1",
                    (ticker,),
                ).fetchone()
                conn.close()
                if row:
                    out = dict(row)
                    out["_table"] = table
                    return out
            except Exception:
                try:
                    if conn is not None:
                        conn.close()
                except Exception:
                    pass
                continue
        return {}

    def _arch_itr_v13_decide(row):
        side = str(
            row.get("best_side")
            or row.get("maker_side")
            or row.get("side")
            or "yes"
        ).lower()

        spread = _arch_itr_v13_safe_float(row.get("spread"), 0.0)
        obi = _arch_itr_v13_safe_float(row.get("order_book_imbalance"), 0.0)
        tox = _arch_itr_v13_safe_float(row.get("maker_toxicity_bps_1s"), 0.0)
        cluster_bias = _arch_itr_v13_safe_float(row.get("cluster_bias_same_side"), 0.0)

        edge = _arch_itr_v13_safe_float(
            row.get("maker_edge_after_rebate_and_inventory"),
            _arch_itr_v13_safe_float(
                row.get("maker_edge_after_rebate"),
                _arch_itr_v13_safe_float(row.get("best_exec_edge"), 0.0),
            ),
        )

        if side == "yes":
            entry_price = _arch_itr_v13_safe_float(row.get("yes_ask"), None)
        else:
            entry_price = _arch_itr_v13_safe_float(row.get("no_ask"), None)

        # Controlled relief, less starved than v12 but still professional.
        if spread <= 0.01:
            required_edge = 0.010
        elif spread <= 0.02:
            required_edge = 0.012
        elif spread <= 0.03:
            required_edge = 0.015
        elif spread <= 0.04:
            required_edge = 0.018
        else:
            required_edge = 999.0

        reasons = []

        if edge < required_edge:
            reasons.append("relief_edge_below_floor")

        if tox >= 4.0:
            reasons.append("relief_toxic_fill_risk_4bps")

        # Important change: neutral / missing OBI (0.0) is NOT hostile.
        # Only block when OBI is meaningfully against the side.
        if side == "yes" and obi < -0.10:
            reasons.append("relief_obi_strongly_against_yes")
        if side == "no" and obi > 0.10:
            reasons.append("relief_obi_strongly_against_no")

        allow = not reasons

        return {
            "ticker": row.get("ticker"),
            "table": row.get("_table"),
            "best_side": side,
            "entry_price": entry_price,
            "spread": spread,
            "order_book_imbalance": obi,
            "maker_toxicity_bps_1s": tox,
            "cluster_bias_same_side": cluster_bias,
            "edge_after_rebate_and_inventory": edge,

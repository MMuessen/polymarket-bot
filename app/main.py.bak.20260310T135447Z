                    maker_shield_reason,
                    cluster_key
                FROM market_opportunities
                WHERE UPPER(ticker) = ?
                ORDER BY id DESC
                LIMIT 1
            """, (ticker,))
            row = cur.fetchone()
            conn.close()
            return dict(row) if row else None
        except Exception as e:
            _arch_ie_v6_stats["last_error"] = repr(e)
            return None

    def _arch_ie_v6_merge(*rows):
        out = {}
        for row in rows:
            if isinstance(row, dict):
                for k, v in row.items():
                    if v is not None:
                        out[k] = v
        return out

    def _arch_ie_v6_entry_price(row):
        side = str(row.get("best_side") or row.get("maker_side") or "yes").lower()
        if side == "no":
            for k in ("no_ask", "entry_price", "price"):
                v = row.get(k)
                if v is not None:
                    try:
                        return float(v)
                    except Exception:
                        pass
        else:
            for k in ("yes_ask", "entry_price", "price"):
                v = row.get(k)
                if v is not None:
                    try:
                        return float(v)
                    except Exception:
                        pass
        return None

    def _arch_ie_v6_reservation_price(row, entry_price):
        try:
            rp = row.get("reservation_price_preview")
            if rp is not None:
                return float(rp)
        except Exception:
            pass
        return entry_price

    def _arch_ie_v6_build_decision(bot_ref, snapshot):
        _arch_ie_v6_stats["decision_calls"] += 1

        ticker = _arch_ie_v6_get_ticker(snapshot)
        if not ticker:
            _arch_ie_v6_stats["hydrated_misses"] += 1
            return {"enforceable": False, "would_block": False, "block_reasons": ["missing_ticker"]}

        health_row = _arch_ie_v6_get_health_row(bot_ref, ticker) or {}
        snap_row = _arch_ie_v6_get_snapshot_row(bot_ref, ticker) or {}
        db_row = _arch_ie_v6_get_db_row(ticker) or {}

        merged = _arch_ie_v6_merge(health_row, snap_row, db_row)
        merged["ticker"] = ticker

        if merged:
            _arch_ie_v6_stats["hydrated_hits"] += 1
        else:
            _arch_ie_v6_stats["hydrated_misses"] += 1

        best_side = str(merged.get("best_side") or merged.get("maker_side") or "yes").lower()
        entry_price = _arch_ie_v6_entry_price(merged)
        reservation_price = _arch_ie_v6_reservation_price(merged, entry_price)
        obi = float(merged.get("order_book_imbalance") or 0.5)
        tox1 = float(merged.get("maker_toxicity_bps_1s") or 0.0)
        spread = float(merged.get("spread") or 0.0)
        edge = merged.get("maker_edge_after_rebate_and_inventory")
        if edge is None:
            edge = merged.get("maker_edge_after_rebate")
        if edge is None:
            edge = merged.get("best_exec_edge")
        try:
            edge = float(edge or 0.0)
        except Exception:
            edge = 0.0

        reasons = []

        if edge <= 0:
            reasons.append("non_positive_edge")

        if entry_price is not None and reservation_price is not None:
            try:
                if float(entry_price) > float(reservation_price) + 1e-9:
                    reasons.append("price_above_reservation")
            except Exception:
                pass

        if best_side == "yes" and obi < -0.5:
            reasons.append("obi_against_yes")
        if best_side == "no" and obi > 0.5:
            reasons.append("obi_against_no")

        if tox1 > 10.0:
            reasons.append("toxic_fill_risk")

        if spread >= 0.08:
            reasons.append("spread_too_wide_for_institutional_gate")

        sample = {
            "ticker": ticker,
            "best_side": best_side,
            "entry_price": entry_price,
            "reservation_price_preview": reservation_price,
            "order_book_imbalance": obi,
            "maker_toxicity_bps_1s": tox1,
            "spread": spread,
            "edge_after_rebate_and_inventory": edge,
            "would_block": bool(reasons),
            "block_reasons": reasons,
        }

        _arch_ie_v6_stats["last_samples"] = ([sample] + _arch_ie_v6_stats["last_samples"])[:10]

        return {
            "enforceable": True,
            "would_block": bool(reasons),
            "block_reasons": reasons,
            "sample": sample,
        }

    def _arch_ie_v6_record(decision):
